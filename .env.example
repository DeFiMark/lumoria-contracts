# Lumoria deployment env vars.
# Copy to .env and fill in before running deploy / verify scripts.

# Deployer private key — funds this account on testnet/mainnet first.
DEPLOYER_PK=

# Platform fee recipient (FeeReceiver). Defaults to deployer if unset.
FEE_RECIPIENT=

# BscScan API key (works for both bsc + bscTestnet via hardhat-verify).
BSCSCAN_API_KEY=

# RPC overrides — leave blank to use the defaults baked into hardhat.config.js.
BSC_RPC=
BSC_TESTNET_RPC=

# Persistent localhost node URL (only set if you've started `npm run node` on
# a non-default port, e.g. 8546).
LOCALHOST_URL=
